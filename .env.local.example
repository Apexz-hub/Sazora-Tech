# Discord Webhooks - Salin ke .env.local dan isi dengan URL webhook Discord Anda
# Tutorial buat webhook: Server Settings > Integrations > Webhooks > New Webhook > Copy URL

DISCORD_WEBHOOK_WEBSITE=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX
DISCORD_WEBHOOK_DISCORD_SERVER=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX
DISCORD_WEBHOOK_DISCORD_BOT=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX
DISCORD_WEBHOOK_WHATSAPP_BOT=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXX

